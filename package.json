{
  "name": "polymarket-seer",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --experimental-https --experimental-https-key ./localhost-key.pem --experimental-https-cert ./localhost.pem -H 0.0.0.0 -p 3000",
    "dev:proxy": "set HTTP_PROXY=http://127.0.0.1:7897 && set HTTPS_PROXY=http://127.0.0.1:7897 && next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "db:migrate": "node scripts/run-db-migrate.mjs"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "@polymarket/builder-relayer-client": "^0.0.10",
    "@polymarket/builder-signing-sdk": "^0.0.8",
    "@polymarket/clob-client-v2": "^1.0.6",
    "@privy-io/react-auth": "^3.16.0",
    "@privy-io/server-auth": "^1.32.5",
    "@types/canvas-confetti": "^1.9.0",
    "canvas-confetti": "^1.9.4",
    "clsx": "^2.1.1",
    "embla-carousel-react": "^8.6.0",
    "ethers": "^5.8.0",
    "html-to-image": "^1.11.13",
    "html2canvas": "^1.4.1",
    "https-proxy-agent": "^9.0.0",
    "lottie-react": "^2.4.1",
    "lucide-react": "^0.577.0",
    "motion": "^12.38.0",
    "nanoid": "^5.1.6",
    "next": "16.1.6",
    "qrcode.react": "^4.2.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-qr-code": "^2.0.18",
    "recharts": "^3.8.0",
    "swr": "^2.4.1",
    "tailwind-merge": "^3.5.0",
    "viem": "^2.46.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "jsdom": "^29.1.1",
    "msw": "^2.14.5",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.5"
  }
}
