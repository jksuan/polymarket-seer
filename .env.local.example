NEXT_PUBLIC_BASE_URL=http://localhost:3000

NEXT_PUBLIC_PRIVY_APP_ID=在此填入你的PrivyAppID

# Telegram 登录（Privy 弹窗入口，默认关闭；身份解析代码仍保留）
# true=在 loginMethods 中启用 telegram，其他值或空=不展示
NEXT_PUBLIC_ENABLE_TELEGRAM_LOGIN=false

# Polymarket Builder API Credentials
# 从 https://polymarket.com/settings?tab=builder 获取
# 这些值仅用于后端，确保不要将其暴露在客户端
POLY_BUILDER_API_KEY=your_api_key_here
POLY_BUILDER_SECRET=your_api_secret_here
POLY_BUILDER_PASSPHRASE=your_api_passphrase_here

# 充值限额
# 单次充值限额，单位：美元。空或无效值时回退到代码默认值。
NEXT_PUBLIC_DEPOSIT_SINGLE_TX_CAP_USD=100000
# Connected Wallet 点击 Max 时的预留缓冲（美元）
NEXT_PUBLIC_CONNECTED_MAX_BUFFER_USD=1

# Debug 开关（仅开发环境生效）
# 1=开启，0/空=关闭
NEXT_PUBLIC_DEBUG_MODE=0
# Transfer 状态轮询调试日志（控制台输出 status 快照与状态迁移）
# 1=开启，0/空=关闭
NEXT_PUBLIC_DEBUG_TRANSFER_STATUS=0

# 测试路由开关（生产环境默认关闭）
# true=允许访问 /testing/*，其他值或空=生产环境下返回 404
NEXT_PUBLIC_ENABLE_TEST_ROUTES=false
